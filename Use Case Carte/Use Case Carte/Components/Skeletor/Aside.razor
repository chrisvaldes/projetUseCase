@using Microsoft.AspNetCore.Components.Authorization
@using Use_Case_Carte.Components.Route
@inject NavigationManager Navigation

@code {

    private string CurrentUri => Navigation.ToBaseRelativePath(Navigation.Uri);

    private bool IsActive(string route)
    {
        route = route.TrimStart('/');

        return CurrentUri.Equals(route, StringComparison.OrdinalIgnoreCase)
            || CurrentUri.StartsWith(route + "/", StringComparison.OrdinalIgnoreCase);
    }

    private bool DashboardOpen =>
        IsActive("MAG/dashboard");

    private bool ProfilOpen =>
        IsActive("MAG/profil")
        || IsActive("MAG/creation-profil")
        || IsActive("MAG/modification-profil")
        || IsActive("MAG/suppression-profil")
        || IsActive("MAG/utilisateurs")
        || IsActive("MAG/nouveau-utilisateur");
    private bool RolePermissionOpen =>
        IsActive("MAG/roles")
        || IsActive("MAG/permissions")
        || IsActive("MAG/nouvelle-permission");

    private bool MagOpen =>
        IsActive("MAG/gestion-mag")
        || IsActive("MAG/nouveau-mag")
        || IsActive("MAG/detail-facturation")
        || IsActive("MAG/Synthese");

}

 