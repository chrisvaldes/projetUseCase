
@page "/MAG/detail-facturation"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
  
@{ 
    var totalMontant = customerBilling.CustomerBillingSynthese.Sum(x => x.MontantTotal);
}

<div class="d-flex align-items-center justify-content-between page-header-breadcrumb flex-wrap gap-2">
    <div>
        <nav>
            <ol class="breadcrumb mb-1">
                <li class="breadcrumb-item fw-bold">
                    <a @onclick="OnCancel">Gestion des cartes client</a>
                </li>
                <i class="ri-arrow-right-s-line side-menu__angle"></i>
                <li class="active">Liste des cartes</li>
            </ol>
        </nav>
    </div>
</div> 
<div class="row mx-1">
    @foreach (var item in customerBilling.CustomerBillingSynthese)
    {
        <div class="col-lg-3 col-xl-4">
            <div class="card custom-card overflow-hidden main-content-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <div class="flex-fill fs-13 text-muted">@item.DesignationCarte</div>
                            <div class="fs-16 fw-medium my-1"><span class="text-danger">@item.MontantTotal!.Value.ToString("N0")</span> XAF</div>
                            <div class="text-muted fs-13">
                                @{
                                    var label = @item.NombreClients > 1 ? "Total de mois prélevés" : "Total de mois prélevé";
                                }

                                @label :
                                <span class="text-success fw-bold fs-15">
                                    @item.NombreClients 
                                    <i class="fa fa-trending-up fs-16"></i>
                                </span> 
                            </div>
                        </div>
                        <div class="avatar avatar-md bg-primary svg-white">
                            @item.CodeCarte
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }


    <div class="col-12 card border border-primary2 border-opacity-25 custom-card " style="background-color : #20c997">
        <div class="card-body">
            <div class="d-flex gap-2 align-items-center my-1">
                <div class="text-fixed-white">
                    <span class="mb-1 d-block">Montant total Prélevé</span>
                    <h4 class="mb-1 text-fixed-white">@totalMontant!.Value.ToString("N0") XAF</h4>
                </div>
                <div class="avatar avatar-lg bg-white-transparent svg-white ms-auto shadow-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="#000000"
                         viewBox="0 0 256 256">
                        <path d="M230.33,141.06a24.43,24.43,0,0,0-21.24-4.23l-41.84,9.62A28,28,0,0,0,140,112H89.94a31.82,31.82,0,0,0-22.63,9.37L44.69,144H16A16,16,0,0,0,0,160v40a16,16,0,0,0,16,16H120a7.93,7.93,0,0,0,1.94-.24l64-16a6.94,6.94,0,0,0,1.19-.4L226,182.82l.44-.2a24.6,24.6,0,0,0,3.93-41.56ZM16,160H40v40H16Zm203.43,8.21-38,16.18L119,200H56V155.31l22.63-22.62A15.86,15.86,0,0,1,89.94,128H140a12,12,0,0,1,0,24H112a8,8,0,0,0,0,16h32a8.32,8.32,0,0,0,1.79-.2l67-15.41.31-.08a8.6,8.6,0,0,1,6.3,15.9ZM164,96a36,36,0,0,0,5.9-.48,36,36,0,1,0,28.22-47A36,36,0,1,0,164,96Zm60-12a20,20,0,1,1-20-20A20,20,0,0,1,224,84ZM164,40a20,20,0,0,1,19.25,14.61,36,36,0,0,0-15,24.93A20.42,20.42,0,0,1,164,80a20,20,0,0,1,0-40Z">
                        </path>
                    </svg>
                </div>
            </div>
        </div>
    </div>
</div>
 
<div class="row d-flex align-items-center justify-content-center">
    <div class="col-12"> 
        <div class="card custom-card">

            <!-- FORMULAIRE -->
            <div class="card-header d-flex align-items-center justify-content-between">
                <div class="card-title">Liste des cartes</div>

                <EditForm FormName="customerBilling" Model="inputBilling" OnInvalidSubmit="Submit" class="d-block" 
                      id="Detail-mag-client">

                    <div class="d-flex align-items-end gap-2">

                        <div>
                            <label>Début</label>
                            <InputDate @bind-Value="inputBilling.Debut" class="form-control" required />
                        </div>

                        <div>
                            <label>Fin</label>
                            <InputDate  @bind-Value="inputBilling.Fin" class="form-control" />
                        </div>

                        <div>

                            <label for="searchInput">Num Compte</label>

                            <div class="position-relative">

                                <InputText  @bind-Value="inputBilling.NumeroCompte"  
                                       class="form-control pe-5"
                                       required />

                                <!-- Bouton clear -->
                                <span id="clearSearch"
                                      class="position-absolute top-50 end-0 translate-middle-y me-3"
                                      style="cursor:pointer; display:none; z-index:10;">

                                    <i class="fa-solid fa-xmark text-muted"></i>

                                </span>

                            </div>

                        </div>

                        <div>
                            <button @onclick="() => GetCustomerBilling()"  class="btn btn-primary">
                                <i class="fa fa-search"></i>
                            </button>
                        </div>

                    </div>
                </EditForm>
            </div>

            <div class="card-body">

                <div class="card-body">
                    <div class="table-responsive">
                        <table id="usersTable" class="table table-hover text-nowrap table-bordered">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Num compte</th>
                                    <th>Code carte</th>
                                    <th>Montant prélevé</th>
                                    <th>Lib carte</th>
                                    <th>Date prélèvement</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (customerBilling != null && customerBilling.BkmvtiResults.Any())
                                {
                                    int i = 1;
                                    foreach (var item in customerBilling.BkmvtiResults)
                                    {
                                        <tr>
                                            <td class="text-center">@i</td>
                                            <td class="text-center">@item.NumeroCompte</td>
                                            <td class="text-center">@item.CodeCarte</td>
                                            <td class="text-center">@item.Montant</td>
                                            <td class="text-center">@item.LibelleCarte</td>
                                            <td class="text-center">@item.DatePrelevement.ToString("dd/MM/yyyy")</td>
                                        </tr>
                                        i++;
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="6" class="text-center text-danger">
                                            Aucun résultat
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        <div class="card-footer">

                            <div class="d-flex align-items-center">

                                <div>
                                    <small id="resultCount" class="text-muted"></small>
                                </div>

                                <div class="ms-auto">

                                    <nav aria-label="Page navigation"
                                         class="pagination-style-4">

                                        <ul class="pagination mb-0" id="paginationContainer">

                                            <!-- PREV -->
                                            <li class="page-item" id="prevPageItem">

                                                <a class="page-link"
                                                   href="javascript:void(0);"
                                                   id="prevPage">

                                                    Prec

                                                </a>

                                            </li>

                                            <!-- NUMEROS -->
                                            <span id="pageNumbers"
                                                  class=" "></span>

                                            <!-- NEXT -->
                                            <li class="page-item" id="nextPageItem">

                                                <a class="page-link text-primary"
                                                   href="javascript:void(0);"
                                                   id="nextPage">

                                                    Suiv

                                                </a>

                                            </li>

                                        </ul>

                                    </nav>

                                </div>

                            </div>

                        </div>

                    </div>
                </div>

            </div>

        </div>
    </div>
</div>